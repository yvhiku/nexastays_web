{
  "name": "nexa-stays-landing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-safe.mjs",
    "dev:quick": "next dev -p 3005",
    "clean:next": "node -e \"const fs=require('fs');['.next','node_modules/.cache'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch{}})\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "audit": "npm audit --audit-level=high",
    "audit:osv": "npx --yes @google/osv-scanner@latest -r . || npx --yes osv-scanner@latest -r .",
    "validate:explore-catalog": "npx --yes tsx scripts/validate-explore-catalog.ts",
    "import:explore-city": "npx --yes tsx scripts/import-explore-city.ts",
    "generate:pwa-icons": "npx --yes tsx scripts/generate-pwa-icons.ts",
    "verify:pwa-assets": "npx --yes tsx scripts/verify-pwa-assets.ts",
    "generate:pwa": "npm run generate:pwa-icons && npm run verify:pwa-assets",
    "measure:homepage": "node scripts/measure-homepage.mjs"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.33.0",
    "heic2any": "^0.0.4",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "libphonenumber-js": "^1.12.38",
    "lucide-react": "^0.563.0",
    "next": "^14.2.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-easy-crop": "^5.4.2",
    "react-phone-number-input": "^3.4.17",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "25.1.0",
    "@types/react": "19.2.10",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.50.0",
    "eslint-config-next": "^14.0.0",
    "postcss": "^8.4.31",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
