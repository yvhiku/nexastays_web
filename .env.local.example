# Public API base URLs only — safe for the browser bundle.
# Never put secrets, API keys, DB passwords, or OTP codes in NEXT_PUBLIC_* vars.

NEXT_PUBLIC_IDENTITY_API_BASE_URL=http://127.0.0.1:3001/api/v1
NEXT_PUBLIC_STAYS_API_BASE_URL=http://127.0.0.1:3002/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3005

# Enable service worker in local dev (Android PWA install testing). Off by default to avoid SW cache issues.
# NEXT_PUBLIC_ENABLE_PWA_DEV=true

# Optional first-party analytics endpoint for funnel events.
# Leave unset to log events locally in development.
# NEXT_PUBLIC_ANALYTICS_ENDPOINT=https://example.com/api/analytics/events

# Legacy single-backend URL (remove once web/mobile clients are updated)
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3000/api/v1
