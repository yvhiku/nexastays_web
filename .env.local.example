# Public API base URLs only — safe for the browser bundle.
# Never put secrets, API keys, DB passwords, or OTP codes in NEXT_PUBLIC_* vars.

NEXT_PUBLIC_IDENTITY_API_BASE_URL=http://127.0.0.1:3001/api/v1
NEXT_PUBLIC_STAYS_API_BASE_URL=http://127.0.0.1:3002/api/v1

